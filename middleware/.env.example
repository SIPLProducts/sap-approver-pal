# ---- Middleware server ----
# Port the middleware listens on. Should match "Middleware Port"
# in SAP API Settings → Middleware Configuration.
PORT=3005

# Shared secret. MUST match:
#   1. The MIDDLEWARE_SHARED_SECRET secret in your Lovable Cloud project
#   2. "Proxy Secret / Password" in SAP API Settings → Middleware Configuration
MIDDLEWARE_SHARED_SECRET=123456

# ---- Lovable app ----
# Base URL of the Lovable app. The middleware calls
#   POST {APP_BASE_URL}/api/public/middleware/config
#   POST {APP_BASE_URL}/api/public/middleware/log
# to load SAP configs and write the sync log. No Supabase keys needed locally.
#
# Preview:   https://id-preview--<project-id>.lovable.app
# Published: https://project--<project-id>.lovable.app
APP_BASE_URL=https://id-preview--06a5c0be-58b7-41a6-ac2d-e7706e765b64.lovable.app

# ---- Offline / smoke-test mode ----
# Set to 1 to skip the app call and build a config from the SAP_BP_* env
# vars below. Useful to verify SAP connectivity from the middleware host
# without the Lovable app being reachable.
MIDDLEWARE_MOCK=0

# ---- Timeouts (milliseconds) ----
SAP_REQUEST_TIMEOUT_MS=30000
SAP_CONNECT_TIMEOUT_MS=60000
SAP_HEADERS_TIMEOUT_MS=60000
SAP_BODY_TIMEOUT_MS=60000

# ---- Optional SAP fallbacks ----
# Used in MOCK_MODE, or when the app returns a row without URL/credentials.
# Per-row values from SAP API Settings always win.
SAP_BP_API_URL=
SAP_DMS_API_URL=
SAP_BP_USERNAME=
SAP_BP_PASSWORD=
