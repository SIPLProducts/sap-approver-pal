# ---- Middleware server ----
# Port the middleware listens on. Should match "Middleware Port"
# in SAP API Settings → Middleware Configuration.
PORT=3002

# Shared secret. MUST match "Proxy Secret / Password" saved in
# SAP API Settings → Middleware Configuration.
MIDDLEWARE_SHARED_SECRET=123456

# ---- Lovable Cloud (Supabase) ----
# Required. Used to read SAP API configs, credentials, and write the sync log.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Timeouts (milliseconds) ----
# Outbound SAP call timeout (HEAD probe + invoke).
SAP_REQUEST_TIMEOUT_MS=30000
# HTTP keep-alive timeout for incoming clients.
SAP_CONNECT_TIMEOUT_MS=60000
# Max time to receive incoming request headers.
SAP_HEADERS_TIMEOUT_MS=60000
# Max time to receive incoming request body.
SAP_BODY_TIMEOUT_MS=60000

# ---- Optional SAP fallbacks ----
# Only used when a SAP API Settings row has no endpoint_url / credentials.
# Per-row values from the UI always win.
SAP_BP_API_URL=
SAP_DMS_API_URL=
SAP_BP_USERNAME=
SAP_BP_PASSWORD=
