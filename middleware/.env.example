# Port the middleware listens on. Should match Middleware Port in the UI.
PORT=3002

# Shared secret. MUST match "Proxy Secret / Password" saved in the
# SAP API Settings → Middleware Configuration tab.
SHARED_SECRET=change-me

# Lovable Cloud (Supabase) — used to read API configs and credentials.
# Get these from your Lovable Cloud project settings (Admin only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

LOG_LEVEL=info
